<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bible Quiz for Kids | Daily Prayers & Blessings</title>
<meta name="description" content="A fun and easy Bible quiz for kids ages 4-8. Learn about Noah's Ark, Baby Jesus, David & Goliath and more through simple questions and colorful fun!">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --sky: #e8f4f8;
    --sky-mid: #c8e6f0;
    --blue: #4a90b8;
    --blue-dark: #2d6a8f;
    --gold: #f5c842;
    --gold-dark: #d4a820;
    --white: #ffffff;
    --text: #1a3a4a;
    --text-light: #4a7a90;
    --correct: #5cb85c;
    --wrong: #e05a5a;
    --radius: 16px;
    --shadow: 0 4px 20px rgba(74,144,184,0.15);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { font-family:'Nunito',sans-serif; background:var(--sky); color:var(--text); min-height:100vh; overflow-x:hidden; }
  body::before { content:''; position:fixed; inset:0; background-image: radial-gradient(circle at 15% 20%,rgba(255,255,255,0.7) 0%,transparent 25%), radial-gradient(circle at 85% 15%,rgba(255,255,255,0.5) 0%,transparent 20%), radial-gradient(circle at 50% 80%,rgba(255,255,255,0.4) 0%,transparent 22%); pointer-events:none; z-index:0; }
  .wrap { position:relative; z-index:1; max-width:680px; margin:0 auto; padding:24px 16px 48px; }

  /* Header */
  .header { text-align:center; margin-bottom:28px; }
  .header-badge { display:inline-block; background:var(--blue); color:var(--white); font-family:'Baloo 2',cursive; font-size:11px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; padding:5px 16px; border-radius:20px; margin-bottom:10px; }
  .header h1 { font-family:'Baloo 2',cursive; font-size:clamp(1.8rem,5vw,2.6rem); font-weight:800; color:var(--blue-dark); line-height:1.15; margin-bottom:6px; }
  .header p { font-size:15px; color:var(--text-light); font-weight:600; }

  /* Stars bar */
  .stars-bar { display:flex; align-items:center; justify-content:space-between; background:var(--white); border-radius:var(--radius); padding:12px 20px; margin-bottom:14px; box-shadow:var(--shadow); flex-wrap:wrap; gap:8px; }
  .stars-bar-left { display:flex; align-items:center; gap:8px; }
  .stars-count { font-family:'Baloo 2',cursive; font-size:1.3rem; font-weight:700; color:var(--blue-dark); }
  .stars-label { font-size:13px; color:var(--text-light); font-weight:600; }
  .star-icons { display:flex; gap:3px; flex-wrap:wrap; max-width:200px; }
  .star-icon { font-size:17px; }
  .star-icon.earned { animation:starPop 0.4s ease; }
  @keyframes starPop { 0%{transform:scale(0) rotate(-20deg)}60%{transform:scale(1.3) rotate(10deg)}100%{transform:scale(1) rotate(0)} }
  .progress-pill { font-family:'Baloo 2',cursive; font-size:13px; font-weight:700; color:var(--text-light); background:var(--sky); padding:4px 12px; border-radius:20px; }

  /* Nav row */
  .nav-row { display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap; }
  .nav-btn { display:inline-flex; align-items:center; gap:6px; padding:8px 14px; border-radius:10px; border:2px solid var(--sky-mid); background:var(--white); font-family:'Nunito',sans-serif; font-size:13px; font-weight:700; color:var(--text-light); cursor:pointer; transition:all 0.2s ease; white-space:nowrap; }
  .nav-btn:hover:not(:disabled) { border-color:var(--blue); color:var(--blue); }
  .nav-btn:disabled { opacity:0.35; cursor:default; }
  .nav-btn.danger:hover { border-color:var(--wrong); color:var(--wrong); }
  .nav-btn.pdf-btn { border-color:var(--gold-dark); color:var(--gold-dark); }
  .nav-btn.pdf-btn:hover { background:var(--gold); border-color:var(--gold-dark); color:var(--text); }

  /* Progress bar */
  .prog-bar-wrap { background:var(--sky-mid); border-radius:20px; height:8px; margin-bottom:18px; overflow:hidden; }
  .prog-bar-fill { height:100%; background:linear-gradient(90deg,var(--blue),var(--blue-dark)); border-radius:20px; transition:width 0.4s ease; }

  /* Question card */
  .question-card { background:var(--white); border-radius:var(--radius); padding:28px 28px 24px; box-shadow:var(--shadow); margin-bottom:16px; animation:cardIn 0.35s ease both; }
  @keyframes cardIn { from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)} }
  .question-topic { display:inline-flex; align-items:center; gap:6px; font-size:11px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:var(--blue); margin-bottom:14px; background:var(--sky); padding:4px 12px; border-radius:20px; }
  .question-text { font-family:'Baloo 2',cursive; font-size:clamp(1.1rem,3vw,1.35rem); font-weight:700; color:var(--text); line-height:1.4; margin-bottom:22px; }

  /* Options */
  .options { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
  .option-btn { display:flex; align-items:center; gap:10px; padding:14px 16px; background:var(--sky); border:2.5px solid var(--sky-mid); border-radius:12px; cursor:pointer; font-family:'Nunito',sans-serif; font-size:14px; font-weight:700; color:var(--text); text-align:left; transition:all 0.2s ease; line-height:1.3; }
  .option-btn:hover:not(:disabled) { border-color:var(--blue); background:rgba(74,144,184,0.08); transform:translateY(-2px); }
  .option-btn .emoji { font-size:22px; min-width:28px; text-align:center; }
  .option-btn.correct { background:rgba(92,184,92,0.12); border-color:var(--correct); color:#2d7a2d; }
  .option-btn.wrong { background:rgba(224,90,90,0.10); border-color:var(--wrong); color:#a03030; }
  .option-btn:disabled { cursor:default; }

  /* Feedback */
  .feedback { display:none; align-items:center; gap:10px; margin-top:14px; padding:12px 18px; border-radius:10px; font-family:'Baloo 2',cursive; font-size:1rem; font-weight:700; animation:feedIn 0.3s ease both; }
  @keyframes feedIn { from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)} }
  .feedback.correct { background:rgba(92,184,92,0.12); color:#2d7a2d; display:flex; }
  .feedback.wrong { background:rgba(224,90,90,0.10); color:#a03030; display:flex; }
  .feedback.review { background:var(--sky); color:var(--text-light); display:flex; }
  .feedback-icon { font-size:1.4rem; }

  /* Action row */
  .action-row { display:flex; gap:10px; margin-top:16px; }
  .action-btn { flex:1; padding:14px; font-family:'Baloo 2',cursive; font-size:1rem; font-weight:700; border:none; border-radius:12px; cursor:pointer; transition:all 0.2s ease; letter-spacing:0.03em; }
  .action-btn.primary { background:var(--blue); color:var(--white); }
  .action-btn.primary:hover { background:var(--blue-dark); transform:translateY(-2px); }
  .action-btn.secondary { background:var(--sky); color:var(--blue-dark); border:2px solid var(--sky-mid); }
  .action-btn.secondary:hover { background:var(--sky-mid); }

  /* Exit modal */
  .modal-overlay { display:none; position:fixed; inset:0; background:rgba(26,58,74,0.5); z-index:500; align-items:center; justify-content:center; padding:20px; }
  .modal-overlay.show { display:flex; }
  .modal { background:var(--white); border-radius:var(--radius); padding:32px 28px; max-width:360px; width:100%; text-align:center; box-shadow:0 8px 40px rgba(26,58,74,0.2); animation:cardIn 0.3s ease both; }
  .modal-emoji { font-size:3rem; margin-bottom:12px; display:block; }
  .modal h3 { font-family:'Baloo 2',cursive; font-size:1.4rem; font-weight:800; color:var(--blue-dark); margin-bottom:8px; }
  .modal p { font-size:14px; color:var(--text-light); font-weight:600; margin-bottom:20px; line-height:1.5; }
  .modal-btns { display:flex; gap:10px; }
  .modal-btn { flex:1; padding:12px; font-family:'Baloo 2',cursive; font-size:14px; font-weight:700; border:none; border-radius:10px; cursor:pointer; transition:all 0.2s ease; }
  .modal-btn.primary { background:var(--wrong); color:var(--white); }
  .modal-btn.primary:hover { opacity:0.85; }
  .modal-btn.secondary { background:var(--sky); color:var(--blue-dark); border:2px solid var(--sky-mid); }
  .modal-btn.secondary:hover { background:var(--sky-mid); }

  /* Results */
  .results { display:none; background:var(--white); border-radius:var(--radius); padding:40px 28px; box-shadow:var(--shadow); text-align:center; animation:cardIn 0.4s ease both; }
  .results-emoji { font-size:4rem; margin-bottom:12px; display:block; }
  .results-title { font-family:'Baloo 2',cursive; font-size:clamp(1.6rem,4vw,2.2rem); font-weight:800; color:var(--blue-dark); margin-bottom:8px; }
  .results-score { font-family:'Baloo 2',cursive; font-size:3.5rem; font-weight:800; color:var(--blue); line-height:1; margin:16px 0 8px; }
  .results-label { font-size:15px; color:var(--text-light); font-weight:700; margin-bottom:20px; }
  .results-stars { display:flex; justify-content:center; gap:6px; flex-wrap:wrap; margin:16px 0 24px; font-size:1.8rem; }
  .results-badge { display:inline-block; background:var(--sky); border:2px solid var(--sky-mid); border-radius:12px; padding:10px 22px; font-family:'Baloo 2',cursive; font-size:1rem; font-weight:700; color:var(--blue-dark); margin-bottom:24px; }
  .results-btns { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin-bottom:24px; }
  .results-btn { padding:13px 20px; font-family:'Baloo 2',cursive; font-size:14px; font-weight:700; border:none; border-radius:12px; cursor:pointer; transition:all 0.2s ease; }
  .results-btn.primary { background:var(--blue); color:var(--white); }
  .results-btn.primary:hover { background:var(--blue-dark); }
  .results-btn.secondary { background:var(--sky); color:var(--blue-dark); border:2px solid var(--sky-mid); }
  .results-btn.secondary:hover { background:var(--sky-mid); }
  .results-btn.pdf { background:var(--gold); color:var(--text); border:2px solid var(--gold-dark); }
  .results-btn.pdf:hover { background:var(--gold-dark); color:var(--white); }

  /* Answer review */
  .answer-review { margin-top:12px; text-align:left; }
  .answer-review-title { font-family:'Baloo 2',cursive; font-size:1.1rem; font-weight:700; color:var(--blue-dark); margin-bottom:14px; text-align:center; }
  .answer-item { background:var(--sky); border-radius:10px; padding:12px 16px; margin-bottom:10px; border-left:4px solid var(--sky-mid); }
  .answer-item.correct-item { border-left-color:var(--correct); background:rgba(92,184,92,0.07); }
  .answer-item.wrong-item { border-left-color:var(--wrong); background:rgba(224,90,90,0.06); }
  .answer-item-q { font-weight:700; font-size:14px; color:var(--text); margin-bottom:6px; }
  .answer-item-detail { font-size:13px; font-weight:600; }
  .correct-ans { color:#2d7a2d; }
  .wrong-ans { color:#a03030; }

  /* Start screen */
  .start-screen { background:var(--white); border-radius:var(--radius); padding:40px 28px; box-shadow:var(--shadow); text-align:center; }
  .start-screen-emoji { font-size:3.5rem; margin-bottom:12px; display:block; }
  .start-screen h2 { font-family:'Baloo 2',cursive; font-size:1.6rem; font-weight:800; color:var(--blue-dark); margin-bottom:10px; }
  .start-screen p { font-size:15px; color:var(--text-light); font-weight:600; margin-bottom:24px; line-height:1.6; }
  .start-options { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px; }
  .start-topic-card { background:var(--sky); border:2px solid var(--sky-mid); border-radius:12px; padding:16px 10px; cursor:pointer; transition:all 0.2s ease; text-align:center; }
  .start-topic-card:hover { border-color:var(--blue); transform:translateY(-2px); }
  .start-topic-card.selected { border-color:var(--blue); background:rgba(74,144,184,0.1); }
  .start-topic-card .t-emoji { font-size:2rem; margin-bottom:6px; display:block; }
  .start-topic-card .t-name { font-family:'Baloo 2',cursive; font-size:13px; font-weight:700; color:var(--text); }
  .q-count-row { display:flex; justify-content:center; gap:10px; margin-bottom:24px; flex-wrap:wrap; }
  .q-count-btn { padding:8px 20px; border-radius:20px; border:2px solid var(--sky-mid); background:var(--white); font-family:'Baloo 2',cursive; font-size:14px; font-weight:700; color:var(--text-light); cursor:pointer; transition:all 0.2s ease; }
  .q-count-btn.active,.q-count-btn:hover { background:var(--blue); color:var(--white); border-color:var(--blue); }
  .start-btn { width:100%; padding:18px; background:var(--blue); color:var(--white); font-family:'Baloo 2',cursive; font-size:1.2rem; font-weight:800; border:none; border-radius:12px; cursor:pointer; transition:all 0.2s ease; }
  .start-btn:hover { background:var(--blue-dark); transform:translateY(-2px); }

  /* Confetti */
  .confetti-piece { position:fixed; pointer-events:none; z-index:9999; border-radius:2px; animation:confettiFall linear forwards; }
  @keyframes confettiFall { 0%{transform:translateY(-20px) rotate(0deg);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0} }

  @media (max-width:480px) {
    .options { grid-template-columns:1fr; }
    .action-row { flex-direction:column; }
    .question-card { padding:20px 16px; }
    .results { padding:28px 16px; }
    .nav-row { gap:6px; }
    .nav-btn { font-size:12px; padding:7px 11px; }
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="header">
    <div class="header-badge">✝ Daily Prayers &amp; Blessings</div>
    <h1>⭐ Bible Quiz for Kids</h1>
    <p>Fun questions for little Bible explorers! Ages 4–8</p>
  </div>

  <!-- Start Screen -->
  <div class="start-screen" id="startScreen">
    <span class="start-screen-emoji">📖</span>
    <h2>Ready to Play?</h2>
    <p>Choose a Bible topic and how many questions you want. Collect stars for every right answer!</p>
    <div class="start-options">
      <div class="start-topic-card selected" data-topic="all" onclick="selectTopic(this)"><span class="t-emoji">🌟</span><div class="t-name">All Topics</div></div>
      <div class="start-topic-card" data-topic="creation" onclick="selectTopic(this)"><span class="t-emoji">🌍</span><div class="t-name">Creation</div></div>
      <div class="start-topic-card" data-topic="noahsark" onclick="selectTopic(this)"><span class="t-emoji">🚢</span><div class="t-name">Noah's Ark</div></div>
      <div class="start-topic-card" data-topic="babyjesus" onclick="selectTopic(this)"><span class="t-emoji">⭐</span><div class="t-name">Baby Jesus</div></div>
      <div class="start-topic-card" data-topic="davidgoliath" onclick="selectTopic(this)"><span class="t-emoji">🪨</span><div class="t-name">David &amp; Goliath</div></div>
      <div class="start-topic-card" data-topic="miracles" onclick="selectTopic(this)"><span class="t-emoji">✨</span><div class="t-name">Miracles</div></div>
      <div class="start-topic-card" data-topic="prayer" onclick="selectTopic(this)"><span class="t-emoji">🙏</span><div class="t-name">Prayer &amp; Faith</div></div>
      <div class="start-topic-card" data-topic="animals" onclick="selectTopic(this)"><span class="t-emoji">🦁</span><div class="t-name">Bible Animals</div></div>
    </div>
    <div class="q-count-row">
      <button class="q-count-btn active" onclick="selectCount(this,10)">10 Questions</button>
      <button class="q-count-btn" onclick="selectCount(this,20)">20 Questions</button>
      <button class="q-count-btn" onclick="selectCount(this,30)">30 Questions</button>
    </div>
    <button class="start-btn" onclick="startQuiz()">🚀 Start Quiz!</button>
  </div>

  <!-- Quiz Area -->
  <div id="quizArea" style="display:none;">
    <div class="stars-bar">
      <div class="stars-bar-left">
        <div class="stars-count" id="starCount">0</div>
        <div class="stars-label">⭐ Stars</div>
      </div>
      <div class="star-icons" id="starIcons"></div>
      <div class="progress-pill" id="progressPill">1 / 10</div>
    </div>

    <div class="nav-row">
      <button class="nav-btn" id="backBtn" onclick="goBack()" disabled>⬅️ Previous</button>
      <button class="nav-btn danger" onclick="showExitModal()">🚪 Exit Quiz</button>
      <button class="nav-btn pdf-btn" onclick="downloadQuestionsPDF()">📄 Download Questions</button>
    </div>

    <div class="prog-bar-wrap">
      <div class="prog-bar-fill" id="progBar" style="width:0%"></div>
    </div>

    <div class="question-card" id="questionCard">
      <div class="question-topic" id="questionTopic">📖 Bible</div>
      <div class="question-text" id="questionText">Loading...</div>
      <div class="options" id="optionsGrid"></div>
      <div class="feedback" id="feedback">
        <span class="feedback-icon" id="feedbackIcon"></span>
        <span id="feedbackText"></span>
      </div>
      <div class="action-row">
        <button class="action-btn secondary" id="prevBtn" style="display:none;" onclick="goBack()">⬅️ Previous</button>
        <button class="action-btn primary" id="nextBtn" style="display:none;" onclick="nextQuestion()">Next ➡️</button>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="results" id="results">
    <span class="results-emoji" id="resultsEmoji">🎉</span>
    <div class="results-title" id="resultsTitle">Amazing Job!</div>
    <div class="results-score" id="resultsScore">0/0</div>
    <div class="results-label">stars collected</div>
    <div class="results-stars" id="resultsStars"></div>
    <div class="results-badge" id="resultsBadge">🏅 Bible Explorer</div>
    <div class="results-btns">
      <button class="results-btn primary" onclick="restartSame()">🔄 Play Again</button>
      <button class="results-btn secondary" onclick="goHome()">🏠 New Topic</button>
      <button class="results-btn pdf" onclick="downloadAnswersPDF()">📄 Download Answers PDF</button>
    </div>
    <div class="answer-review" id="answerReview"></div>
  </div>
</div>

<!-- Exit Modal -->
<div class="modal-overlay" id="exitModal">
  <div class="modal">
    <span class="modal-emoji">🚪</span>
    <h3>Exit the Quiz?</h3>
    <p>You have answered <strong id="exitProgress">0</strong> questions so far. Your progress will be lost.</p>
    <div class="modal-btns">
      <button class="modal-btn secondary" onclick="hideExitModal()">Keep Playing</button>
      <button class="modal-btn primary" onclick="confirmExit()">Yes, Exit</button>
    </div>
  </div>
</div>

<script>
const ALL_QUESTIONS = [
  {topic:"creation",emoji:"🌍",q:"Who made the whole world?",opts:["🐻 A bear","🧙 A wizard","🙏 God","👑 A king"],ans:2},
  {topic:"creation",emoji:"🌍",q:"How many days did God take to make the world?",opts:["🌙 3 days","☀️ 6 days","🌟 10 days","🌈 1 day"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What did God make on the very first day?",opts:["🐠 Fish","💡 Light","🌳 Trees","🌙 The moon"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What did God make on Day 6?",opts:["🌊 The sea","⭐ Stars","👨 People","🐦 Birds"],ans:2},
  {topic:"creation",emoji:"🌍",q:"What did God do on Day 7?",opts:["🌊 Made oceans","😴 Rested","🌳 Made trees","🐘 Made elephants"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What was the name of the first man God made?",opts:["🧔 Noah","👦 David","🧑 Adam","👨 Moses"],ans:2},
  {topic:"creation",emoji:"🌍",q:"What was the name of the first woman?",opts:["🌸 Mary","🌺 Eve","🌼 Sarah","🌻 Ruth"],ans:1},
  {topic:"creation",emoji:"🌍",q:"Where did God put Adam and Eve to live?",opts:["🏔️ A mountain","🌳 The Garden of Eden","🏜️ A desert","🏠 A house"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What did God make on Day 2?",opts:["☁️ The sky","🐠 Fish","🌹 Flowers","🌙 The moon"],ans:0},
  {topic:"creation",emoji:"🌍",q:"What did God make on Day 3?",opts:["☀️ The sun","🌊 Dry land and plants","⭐ Stars","🐓 Birds"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What did God make on Day 4?",opts:["🐳 Whales","☀️ Sun moon and stars","🦁 Lions","👨 People"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What did God make on Day 5?",opts:["🐟 Fish and birds","🌳 Trees","💡 Light","👩 Women"],ans:0},
  {topic:"creation",emoji:"🌍",q:"What did God make Eve from?",opts:["🌊 Water","🌱 A plant","🦴 Adam's rib","⭐ A star"],ans:2},
  {topic:"creation",emoji:"🌍",q:"What did Adam and Eve eat that they should not have?",opts:["🍌 Banana","🍎 Fruit from the forbidden tree","🍇 Grapes","🍊 Orange"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What animal tricked Eve in the garden?",opts:["🦁 Lion","🐍 Snake","🐻 Bear","🦊 Fox"],ans:1},
  {topic:"creation",emoji:"🌍",q:"God said His creation was very...?",opts:["🎈 Big","⚡ Scary","✅ Good","💧 Wet"],ans:2},
  {topic:"creation",emoji:"🌍",q:"What did God breathe into Adam to make him alive?",opts:["💨 The breath of life","🌊 Water","🔥 Fire","💡 Light"],ans:0},
  {topic:"creation",emoji:"🌍",q:"What did God plant in the Garden of Eden?",opts:["🏠 A house","🌳 All kinds of trees","🌊 A river","⭐ Stars"],ans:1},
  {topic:"creation",emoji:"🌍",q:"Who named all the animals in the Bible?",opts:["🌸 Eve","🧑 Adam","🐍 The snake","🙏 God"],ans:1},
  {topic:"creation",emoji:"🌍",q:"What were the names of Adam and Eve's first two sons?",opts:["🧒 Noah and Shem","🧒 Cain and Abel","🧒 Peter and Paul","🧒 James and John"],ans:1},
  {topic:"noahsark",emoji:"🚢",q:"What did God tell Noah to build?",opts:["🏠 A house","🌉 A bridge","🚢 A big boat (ark)","🗼 A tower"],ans:2},
