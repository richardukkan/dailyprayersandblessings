let selectedTopic="all",selectedCount=10,currentQuestions=[],currentIndex=0,score=0,answered=false,userAnswers=[];

function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function topicLabel(t){return{creation:"Creation",noahsark:"Noah's Ark",babyjesus:"Baby Jesus",davidgoliath:"David & Goliath",miracles:"Miracles",prayer:"Prayer & Faith",animals:"Bible Animals"}[t]||"Bible";}
function selectTopic(el){document.querySelectorAll('.start-topic-card').forEach(c=>c.classList.remove('selected'));el.classList.add('selected');selectedTopic=el.dataset.topic;}
function selectCount(el,n){document.querySelectorAll('.q-count-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');selectedCount=n;}

function startQuiz(){
  let pool=selectedTopic==="all"?ALL_QUESTIONS:ALL_QUESTIONS.filter(q=>q.topic===selectedTopic);
  if(!pool.length)pool=ALL_QUESTIONS;
  currentQuestions=shuffle(pool).slice(0,Math.min(selectedCount,pool.length));
  currentIndex=0;score=0;userAnswers=[];
  document.getElementById('startScreen').style.display='none';
  document.getElementById('results').style.display='none';
  document.getElementById('quizArea').style.display='block';
  updateStars();showQuestion();
}

