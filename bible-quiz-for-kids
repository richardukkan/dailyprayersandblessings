function downloadAnswersPDF(){
  const L=['A','B','C','D'];
  const total=currentQuestions.length,pct=score/total;
  let badge=pct===1?'🏆 Bible Champion!':pct>=0.8?'⭐ Bible Star!':pct>=0.6?'📖 Bible Explorer!':pct>=0.4?'🌱 Bible Learner!':'🙏 Bible Friend!';
