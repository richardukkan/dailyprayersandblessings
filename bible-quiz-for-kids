  const grid=document.getElementById('optionsGrid');grid.innerHTML='';
  q.opts.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.className='option-btn';
    btn.innerHTML=`<span class="emoji">${emojis[i]}</span><span>${opt}</span>`;
    if(prev!==undefined){
      btn.disabled=true;
      if(i===q.ans)btn.classList.add('correct');
      if(i===prev.chosen&&prev.chosen!==q.ans)btn.classList.add('wrong');
    } else {
      btn.onclick=()=>selectAnswer(i,btn,q.ans);
    }
    grid.appendChild(btn);
  });
  const fb=document.getElementById('feedback');
  if(prev!==undefined){
    fb.className='feedback review';fb.style.display='flex';
    document.getElementById('feedbackIcon').textContent='👀';
    document.getElementById('feedbackText').textContent=prev.wasCorrect?`You got this right! ⭐ Answer: ${q.opts[q.ans]}`:`Correct answer: ${q.opts[q.ans]}`;
    document.getElementById('nextBtn').style.display='block';answered=true;
  } else {
    fb.className='feedback';fb.style.display='none';
    document.getElementById('nextBtn').style.display='none';
  }
  const card=document.getElementById('questionCard');card.style.animation='none';card.offsetHeight;card.style.animation='cardIn 0.35s ease both';
}

function selectAnswer(idx,btn,correct){
  if(answered)return;answered=true;
  document.querySelectorAll('.option-btn').forEach(b=>b.disabled=true);
  const wasCorrect=idx===correct;
  userAnswers[currentIndex]={chosen:idx,correct,wasCorrect};
  if(wasCorrect){score++;btn.classList.add('correct');showFeedback(true);updateStars();launchConfetti();}
  else{btn.classList.add('wrong');document.querySelectorAll('.option-btn')[correct].classList.add('correct');showFeedback(false);}
  document.getElementById('nextBtn').style.display='block';
}

function showFeedback(ok){
  const fb=document.getElementById('feedback');
  const okMsgs=["That's right! 🎉","Amazing!","Wonderful! ⭐","Yes! You got it!","Super! Keep going!","Brilliant! 🌟","Correct!","Fantastic! 🎊"];
  const noMsgs=["Not quite — keep trying!","Almost!","Good try!","Learning is fun!","You'll remember next time! 💙","Keep going!"];
  fb.className=`feedback ${ok?'correct':'wrong'}`;fb.style.display='flex';
  document.getElementById('feedbackIcon').textContent=ok?'🌟':'💙';
  document.getElementById('feedbackText').textContent=ok?okMsgs[Math.floor(Math.random()*okMsgs.length)]:noMsgs[Math.floor(Math.random()*noMsgs.length)];
}

function nextQuestion(){currentIndex++;if(currentIndex>=currentQuestions.length)showResults();else showQuestion();}
function goBack(){if(currentIndex===0)return;currentIndex--;showQuestion();}
function showExitModal(){document.getElementById('exitProgress').textContent=userAnswers.filter(Boolean).length;document.getElementById('exitModal').classList.add('show');}
function hideExitModal(){document.getElementById('exitModal').classList.remove('show');}
function confirmExit(){hideExitModal();document.getElementById('quizArea').style.display='none';document.getElementById('results').style.display='none';document.getElementById('startScreen').style.display='block';score=0;currentIndex=0;userAnswers=[];updateStars();}

function updateStars(){
  document.getElementById('starCount').textContent=score;
  const icons=document.getElementById('starIcons');icons.innerHTML='';
  const show=Math.min(score,12);
  for(let i=0;i<show;i++){const s=document.createElement('span');s.className='star-icon'+(i===score-1?' earned':'');s.textContent='⭐';icons.appendChild(s);}
  if(score>12){const m=document.createElement('span');m.style.cssText='font-size:12px;color:var(--text-light);font-weight:700;';m.textContent=`+${score-12}`;icons.appendChild(m);}
}

function launchConfetti(){
  const colors=['#4a90b8','#f5c842','#c8e6f0','#ffffff','#2d6a8f'];
  for(let i=0;i<24;i++){const c=document.createElement('div');c.className='confetti-piece';c.style.cssText=`left:${Math.random()*100}vw;top:0;background:${colors[Math.floor(Math.random()*colors.length)]};animation-duration:${0.9+Math.random()*0.8}s;animation-delay:${Math.random()*0.3}s;width:${6+Math.random()*6}px;height:${6+Math.random()*6}px;border-radius:${Math.random()>0.5?'50%':'2px'};`;document.body.appendChild(c);setTimeout(()=>c.remove(),2200);}
}

function showResults(){
  document.getElementById('progBar').style.width='100%';
  document.getElementById('quizArea').style.display='none';
  const res=document.getElementById('results');res.style.display='block';
  const total=currentQuestions.length,pct=score/total;
  let emoji='🌟',title='',badge='';
  if(pct===1){emoji='🏆';title='Perfect Score!';badge='🏆 Bible Champion!';}
  else if(pct>=0.8){emoji='🌟';title='Amazing Job!';badge='⭐ Bible Star!';}
  else if(pct>=0.6){emoji='😊';title='Well Done!';badge='📖 Bible Explorer!';}
  else if(pct>=0.4){emoji='💙';title='Good Try!';badge='🌱 Bible Learner!';}
  else{emoji='🤗';title='Keep Practising!';badge='🙏 Bible Friend!';}
  document.getElementById('resultsEmoji').textContent=emoji;
  document.getElementById('resultsTitle').textContent=title;
  document.getElementById('resultsScore').textContent=`${score}/${total}`;
  document.getElementById('resultsBadge').textContent=badge;
  const sd=document.getElementById('resultsStars');sd.innerHTML='';
  for(let i=0;i<Math.min(score,20);i++){const s=document.createElement('span');s.textContent='⭐';sd.appendChild(s);}
  // Answer review
  const rev=document.getElementById('answerReview');
  rev.innerHTML=`<div class="answer-review-title">📋 Your Answers</div>`;
  currentQuestions.forEach((q,i)=>{
    const ua=userAnswers[i];
    const item=document.createElement('div');
    item.className='answer-item '+(ua?(ua.wasCorrect?'correct-item':'wrong-item'):'');
    item.innerHTML=`<div class="answer-item-q">${i+1}. ${q.q}</div>
    <div class="answer-item-detail">${ua&&ua.wasCorrect?`<span class="correct-ans">✅ Correct: ${q.opts[q.ans]}</span>`:`${ua?`<span class="wrong-ans">❌ Your answer: ${q.opts[ua.chosen]}</span> &nbsp; `:'<span class="wrong-ans">— Not answered</span> &nbsp; '}<span class="correct-ans">✅ Answer: ${q.opts[q.ans]}</span>`}</div>`;
    rev.appendChild(item);
  });
  if(pct>=0.8){for(let i=0;i<3;i++)setTimeout(()=>launchConfetti(),i*400);}
}

function restartSame(){startQuiz();}
function goHome(){document.getElementById('results').style.display='none';document.getElementById('quizArea').style.display='none';document.getElementById('startScreen').style.display='block';score=0;currentIndex=0;userAnswers=[];updateStars();}

// PDF HELPERS
function openPrintWindow(html){
  const w=window.open('','_blank');
  if(!w){alert('Please allow pop-ups to download the PDF.');return;}
  w.document.write(html);w.document.close();w.focus();
  setTimeout(()=>w.print(),700);
}

